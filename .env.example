# Copie este arquivo para .env. Nunca commite o .env.
# Bridge HTTP/SSE (os padrões abaixo são para desenvolvimento local)
PIXEL_BRIDGE_HOST=127.0.0.1
PIXEL_BRIDGE_PORT=8787
# Troque os dois valores de token pelo mesmo segredo local.
PIXEL_BRIDGE_TOKEN=troque-este-token-local
PIXEL_BRIDGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PIXEL_BRIDGE_BODY_LIMIT=4194304

# Development only. In production, keep this unset and define PIXEL_BRIDGE_TOKEN.
# PIXEL_BRIDGE_DEV=1

# Web client. Variáveis VITE_* chegam ao navegador: não use segredos de APIs.
VITE_PIXEL_BRIDGE_URL=http://localhost:8787
VITE_PIXEL_BRIDGE_TOKEN=troque-este-token-local

# Runtime files. PIXEL_RUNTIME_DIR define os padrões; os caminhos explícitos
# abaixo têm precedência. Use caminhos absolutos se bridge e MCP tiverem cwd
# diferentes.
PIXEL_RUNTIME_DIR=./runtime
PIXEL_PROJECT_PATH=./runtime/pixel-project.mcp.json
PIXEL_DB_PATH=./runtime/pixel-art-db.json
PIXEL_SQLITE_PATH=./runtime/editor.sqlite

# External AI provider. Deixe PIXEL_AI_ENDPOINT vazio/comentado para usar o
# fallback heurístico local (não é IA generativa real).
# PIXEL_AI_ENDPOINT=http://127.0.0.1:9000/generate
# PIXEL_AI_API_KEY=opcional
# PIXEL_AI_TIMEOUT_MS=15000
# PIXEL_AI_MAX_RESPONSE_BYTES=2097152

# Contrato: POST application/json com prompt, operação, projeto compacto,
# seleção, paleta e constraints. A resposta deve conter project, frames ou diff.
# Erros acionam fallback local identificado explicitamente como heurístico.
