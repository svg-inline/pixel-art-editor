{
  "name": "pixel-art-mcp",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web": "vite --host 0.0.0.0",
    "bridge": "tsx server/bridge-server.ts",
    "mcp": "tsx server/mcp-server.ts",
    "dev": "concurrently \"npm run bridge\" \"npm run web\"",
    "dev:all": "concurrently \"npm run bridge\" \"npm run web\" \"npm run mcp\"",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.0",
    "typescript": "6.0.3",
    "tsx": "4.22.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "concurrently": "10.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  }
}
