{
  "name": "pixel-art-mcp",
  "version": "2.0.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "type": "module",
  "scripts": {
    "web": "vite --host 0.0.0.0",
    "bridge": "tsx server/bridge-server.ts",
    "mcp": "tsx server/mcp-server.ts",
    "dev": "concurrently \"npm run bridge\" \"npm run web\"",
    "dev:all": "concurrently \"npm run bridge\" \"npm run web\" \"npm run mcp\"",
    "runtime:status": "tsx server/runtime-maintenance.ts status",
    "runtime:migrate": "tsx server/runtime-maintenance.ts migrate",
    "runtime:reset": "tsx server/runtime-maintenance.ts reset",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "build": "vite build",
    "pack:clean": "node scripts/pack-clean.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.0",
    "typescript": "6.0.3",
    "tsx": "4.22.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "concurrently": "10.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  }
}
